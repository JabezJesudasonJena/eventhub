# ======================
# DATABASE CONFIGURATION
# ======================

# PostgreSQL Connection String (Neon or other PostgreSQL provider)
# Get this from your Neon dashboard: https://neon.tech
# Format: postgresql://username:password@host/database?sslmode=require
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/neondb?sslmode=require

# ======================
# SERVER CONFIGURATION
# ======================

# Server Port
PORT=3000

# Node Environment (development, production)
NODE_ENV=development

# CORS Origin (comma-separated for multiple origins)
CORS_ORIGIN=*

# ======================
# AUTHENTICATION
# ======================

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# JWT Token Expiration
JWT_EXPIRES_IN=24h

# ======================
# SECURITY
# ======================

# Bcrypt Hash Rounds (10-12 recommended)
BCRYPT_ROUNDS=10

